    "@tiptap/extension-typography": "^2.2.0",
    "@tiptap/extension-underline": "^2.2.0",
    "@tiptap/pm": "^2.2.0",
    "@tiptap/react": "^2.2.0",
    "@tiptap/starter-kit": "^2.2.0",
    "html-to-docx": "^1.8.0",
    "jose": "^6.2.1",
