    "@tiptap/extension-code-block-lowlight": "^2.2.0",
    "@tiptap/extension-color": "^2.2.0",
    "@tiptap/extension-dropcursor": "^2.2.0",
    "@tiptap/extension-floating-menu": "^2.27.2",
    "@tiptap/extension-font-family": "^2.2.0",
    "@tiptap/extension-highlight": "^2.2.0",
    "@tiptap/extension-image": "^2.2.0",
    "@tiptap/extension-link": "^2.2.0",
    "@tiptap/extension-placeholder": "^2.2.0",
    "@tiptap/extension-subscript": "^2.2.0",
    "@tiptap/extension-superscript": "^2.2.0",
    "@tiptap/extension-table": "^2.2.0",
