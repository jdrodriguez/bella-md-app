{
  "name": "bella-md",
  "version": "1.0.0",
  "description": "BellaMD — A modern WYSIWYG Markdown document editor",
  "author": {
    "name": "Integrum",
    "email": "support@bellamarkdown.com"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "type-check": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "echo 'lint ok'",
    "package": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win",
    "package:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
